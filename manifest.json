{
  "manifest_version": 3,
  "name": "TabVault Pro",
  "version": "1.0",
  "description": "Save and manage your browser tabs.",
  "permissions": [
    "tabs",
    "storage",
    "favicon",
    "windows",
    "contextMenus",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Open TabVault Pro"
  }
}
