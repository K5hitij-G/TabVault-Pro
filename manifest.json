{
  "manifest_version": 3,
  "name": "TabVault Pro",
  "version": "1.0",
  "description": "Save and manage your browser tabs.",
  "permissions": [
    "tabs",
    "storage",
    "favicon",
    "windows",
    "contextMenus",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Open TabVault Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
